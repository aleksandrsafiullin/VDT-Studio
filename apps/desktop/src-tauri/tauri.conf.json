{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VDT Studio",
  "version": "0.1.0-alpha.0",
  "identifier": "com.vdtstudio.desktop",
  "build": {
    "beforeDevCommand": "NEXT_PUBLIC_VDT_APP_MODE=desktop pnpm --filter @vdt-studio/web dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "NEXT_PUBLIC_VDT_APP_MODE=desktop pnpm --filter @vdt-studio/web build",
    "frontendDist": "../web/.next"
  },
  "app": {
    "windows": [
      {
        "title": "VDT Studio",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:3000; connect-src 'self' http://localhost:3000 https:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["all"],
    "resources": [
      "sidecars/vdt-local-runtime",
      "sidecars/vdt-local-runtime.cmd",
      "sidecars/vdt-local-runtime.mjs",
      "sidecars/vdt-local-runtime.manifest.json",
      "sidecars/vdt-agent-skills"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
