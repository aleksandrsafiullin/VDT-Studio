{
  "schema_version": "1.0",
  "id": "mining.excavation.evals",
  "skill_id": "mining.excavation",
  "version": 3,
  "status": "draft_regression_suite",
  "purpose": "Regression tests for the Mining Excavation VDT skill. This file is for CI/harness validation, not for user-facing default suggestions.",
  "global_forbidden_nodes": [
    "truck_fleet_capacity",
    "truck_arrival_rate",
    "truck_queueing_time",
    "haul_route_cycle_time",
    "dispatch_match_factor",
    "dumping_capacity",
    "processing_throughput",
    "material_ready_for_excavation_cap",
    "operating_area_access_cap",
    "drilling_blasting_readiness_cap"
  ],
  "assertion_schema": {
    "required_nodes": "All listed node IDs or semantic equivalents must exist.",
    "forbidden_nodes": "None of the listed node IDs or semantic equivalents may exist.",
    "required_formulas": "The response graph must contain formulas equivalent to these strings.",
    "assumption_assertions": "Default/unknown values must be visible in node metadata.",
    "numeric_assertions": "Formula-engine checks with tolerance. Use after graph conversion."
  },
  "tests": [
    {
      "id": "ore_output_canonical_unknown_values",
      "name": "Build canonical ore excavation VDT with unknown numeric leaves",
      "user_prompt": "Build a VDT for monthly ore excavation output by excavators. I do not know the input values yet.",
      "expected": {
        "root_candidates": [
          "ore_excavation_output_t",
          "excavation_output"
        ],
        "required_nodes": [
          "active_excavator_count",
          "net_excavation_time_per_excavator_h",
          "calendar_time_per_excavator_h",
          "period_days",
          "hours_per_day_24",
          "downtime_per_excavator_h",
          "ore_excavator_productivity_tph",
          "loaded_trucks_per_hour",
          "truck_loading_time_min",
          "tonnes_per_truck",
          "tonnes_per_bucket",
          "average_bucket_volume_m3",
          "ore_density_in_solid_t_per_m3",
          "swell_factor",
          "actual_bucket_fill_factor"
        ],
        "required_formulas": [
          "calendar_time_per_excavator_h = period_days * 24",
          "net_excavation_time_per_excavator_h = calendar_time_per_excavator_h - downtime_per_excavator_h",
          "ore_excavator_productivity_tph = loaded_trucks_per_hour * tonnes_per_truck"
        ],
        "forbidden_nodes": [
          "truck_fleet_capacity",
          "haul_route_cycle_time",
          "truck_queueing_time"
        ],
        "assumption_assertions": {
          "missing_numeric_values_status": "unknown_or_default_assumption",
          "defaults_must_not_be_silent": true
        }
      }
    },
    {
      "id": "rock_productivity_solid_m3_branch",
      "name": "Rock productivity must use solid cubic meters and swell conversion",
      "user_prompt": "Create a VDT for rock excavation productivity in m3 per hour.",
      "expected": {
        "root_candidates": [
          "rock_excavator_productivity_m3ph"
        ],
        "required_nodes": [
          "loaded_trucks_per_hour",
          "rock_volume_per_truck_in_solid_m3",
          "buckets_per_truck",
          "rock_volume_per_bucket_in_solid_m3",
          "average_bucket_volume_m3",
          "swell_factor",
          "actual_bucket_fill_factor"
        ],
        "required_formulas": [
          "rock_volume_per_bucket_in_solid_m3 = average_bucket_volume_m3 / swell_factor * actual_bucket_fill_factor",
          "rock_excavator_productivity_m3ph = loaded_trucks_per_hour * rock_volume_per_truck_in_solid_m3"
        ],
        "forbidden_nodes": [
          "ore_density_in_solid_t_per_m3",
          "tonnes_per_bucket",
          "truck_fleet_capacity"
        ]
      }
    },
    {
      "id": "fleet_downtime_no_double_count",
      "name": "Fleet downtime must not be multiplied by active excavator count twice",
      "user_prompt": "We have 3 active excavators, 10 days, and total fleet downtime of 60 hours. Build excavation capacity VDT.",
      "expected": {
        "required_warnings": [
          "downtime basis is fleet total and must be converted or modeled as fleet net time"
        ],
        "allowed_formula_patterns": [
          "fleet_net_excavation_time_h = active_excavator_count * period_days * 24 - fleet_downtime_h",
          "downtime_per_excavator_h = fleet_downtime_h / active_excavator_count"
        ],
        "forbidden_formula_patterns": [
          "excavation_output = active_excavator_count * (active_excavator_count * period_days * 24 - fleet_downtime_h) * excavator_productivity"
        ]
      }
    },
    {
      "id": "mixed_units_do_not_sum",
      "name": "Ore tonnes and rock cubic meters must not be summed without convention",
      "user_prompt": "Build one total excavation output tree for ore tonnes and waste rock cubic meters.",
      "expected": {
        "required_warnings": [
          "ore tonnes and rock cubic meters cannot be summed without an explicit reporting convention"
        ],
        "required_nodes_any": [
          [
            "ore_excavation_output_t",
            "rock_excavation_output_solid_m3"
          ],
          [
            "material_output_split"
          ]
        ],
        "forbidden_formulas": [
          "total_excavation_output = ore_excavation_output_t + rock_excavation_output_solid_m3"
        ]
      }
    },
    {
      "id": "equipment_mix_split",
      "name": "Different equipment classes should be split when productivity drivers differ",
      "user_prompt": "Build excavation capacity VDT for two Cat 6060 hydraulic shovels and one rope shovel. They have different bucket sizes and downtime.",
      "expected": {
        "required_nodes": [
          "hydraulic_shovel_excavation_output",
          "rope_shovel_excavation_output"
        ],
        "required_formulas": [
          "total_excavation_output = sum(equipment_class_excavation_output)"
        ],
        "forbidden_nodes": [
          "single_average_excavator_productivity_without_assumption"
        ]
      }
    },
    {
      "id": "readiness_access_are_downtime_not_caps",
      "name": "Readiness and access restrictions reduce time through downtime",
      "user_prompt": "Excavation is lower because blasted material was not ready for 6 hours and operating area access was restricted for 4 hours. Build a VDT.",
      "expected": {
        "required_nodes": [
          "excavation_output",
          "net_excavation_time_per_excavator_h",
          "downtime_per_excavator_h",
          "material_or_face_not_ready_time_h",
          "operating_area_access_restriction_time_h"
        ],
        "required_formulas": [
          "net_excavation_time_per_excavator_h = calendar_time_per_excavator_h - downtime_per_excavator_h",
          "downtime_per_excavator_h = sum(downtime_categories)"
        ],
        "forbidden_nodes": [
          "material_ready_for_excavation_cap",
          "operating_area_access_cap",
          "actual_excavation_output_min_cap_branch"
        ],
        "forbidden_formula_patterns": [
          "actual_excavation_output = min(calculated_excavation_capacity, material_ready_for_excavation, operating_area_access)",
          "actual_excavation_output = calculated_excavation_capacity * material_readiness_factor"
        ],
        "numeric_assertions": [
          {
            "node_id": "downtime_per_excavator_h_partial_sum",
            "expected_value": 10.0,
            "tolerance": 0.0001,
            "inputs": {
              "material_or_face_not_ready_time_h": 6.0,
              "operating_area_access_restriction_time_h": 4.0
            }
          }
        ]
      }
    },
    {
      "id": "defaults_visible_in_dialog",
      "name": "Default suggestions must be visible in dialog and marked as assumptions",
      "user_prompt": "I do not know fill factor or swell factor. Use defaults for average blasted ore with a hydraulic shovel.",
      "expected": {
        "required_assumption_metadata": [
          {
            "node_id": "actual_bucket_fill_factor",
            "value": 0.825,
            "range": [
              0.75,
              0.9
            ],
            "assumption_status": "default_assumption",
            "editable_in_dialog": true,
            "accepted_by_user_in_dialog": true
          },
          {
            "node_id": "swell_factor",
            "value": 1.6,
            "range": [
              1.45,
              1.7
            ],
            "assumption_status": "default_assumption",
            "editable_in_dialog": true,
            "accepted_by_user_in_dialog": true
          }
        ],
        "forbidden_behavior": [
          "silent_default_application"
        ]
      }
    },
    {
      "id": "formula_numeric_ore_productivity_example",
      "name": "Formula sanity check for ore productivity using example inputs",
      "input_values": {
        "average_bucket_volume_m3": 12.0,
        "ore_density_in_solid_t_per_m3": 2.26,
        "swell_factor": 1.6,
        "actual_bucket_fill_factor": 0.825,
        "buckets_per_truck": 5,
        "bucket_cycle_time_sec": 29,
        "face_breakdown_ripping_time_min": 0.25,
        "truck_departure_arrival_time_min": 0.75,
        "relocation_time_min": 0.0
      },
      "numeric_assertions": [
        {
          "node_id": "loading_movement_unloading_time_min",
          "expected_value": 2.4166667,
          "tolerance": 0.0001
        },
        {
          "node_id": "truck_loading_time_min",
          "expected_value": 3.4166667,
          "tolerance": 0.0001
        },
        {
          "node_id": "loaded_trucks_per_hour",
          "expected_value": 17.5609756,
          "tolerance": 0.0001
        },
        {
          "node_id": "tonnes_per_bucket",
          "expected_value": 13.98375,
          "tolerance": 0.0001
        },
        {
          "node_id": "tonnes_per_truck",
          "expected_value": 69.91875,
          "tolerance": 0.0001
        },
        {
          "node_id": "ore_excavator_productivity_tph",
          "expected_value": 1227.8414634,
          "tolerance": 0.001
        }
      ]
    },
    {
      "id": "forbidden_haulage_creep",
      "name": "Excavation VDT must not drift into haulage",
      "user_prompt": "Explain excavation output through loaded trucks per hour and material per truck, but keep it excavation-only.",
      "expected": {
        "required_nodes": [
          "loaded_trucks_per_hour",
          "material_per_truck"
        ],
        "forbidden_nodes": [
          "truck_fleet_capacity",
          "truck_arrival_rate",
          "haul_route_cycle_time",
          "truck_queueing_time",
          "dumping_capacity"
        ]
      }
    },
    {
      "id": "question_policy_first_pass_tree",
      "name": "Agent should build first-pass tree and ask only needed topology questions",
      "user_prompt": "Make me a VDT for excavator capacity.",
      "expected": {
        "must_produce_tree": true,
        "max_topology_questions_before_tree": 4,
        "must_not_ask": [
          "How many hours are in a day?",
          "Should I expand this into haulage?",
          "What is truck route cycle time?",
          "Do you want to open Missing Inputs panel?"
        ],
        "must_use_dialog_only_input_collection": true
      }
    }
  ]
}
