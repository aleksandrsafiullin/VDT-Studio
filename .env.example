# AI provider defaults
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4.1-mini

# Server-side research provider for research.search_web.
# Supported values: brave, tavily, noop. Leave unset for controlled Noop fallback.
VDT_RESEARCH_PROVIDER=noop
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
VDT_RESEARCH_TIMEOUT_MS=10000
VDT_RESEARCH_MAX_RESULTS=5

# Local runner
LOCAL_RUNNER_URL=http://localhost:8765
