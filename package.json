{
  "name": "vdt-studio",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "AI-first, local-first Value Driver Tree workspace for editable and calculable KPI driver models.",
  "license": "MIT",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10.33 <11"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @vdt-studio/web dev",
    "build": "pnpm build:cli && pnpm build:web",
    "build:cli": "pnpm --filter @vdt-studio/cli build",
    "build:web": "pnpm --filter @vdt-studio/web build",
    "start": "pnpm --filter @vdt-studio/web start",
    "lint": "pnpm --filter @vdt-studio/web lint",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "vdt": "tsx packages/cli/src/bin.ts",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm local-runner:start\"",
    "local-runner:start": "tsx packages/local-runner/src/server/index.ts",
    "security:audit": "pnpm audit --prod --audit-level high",
    "certification:verify": "node scripts/verify-provider-certification.mjs",
    "package:alpha": "node scripts/package-alpha.mjs",
    "package:verify": "node scripts/verify-cli-package.mjs",
    "release:verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm security:audit && pnpm certification:verify && pnpm package:alpha && pnpm package:verify"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.0.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
