{
  "name": "vdt-studio",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "AI-first, local-first Value Driver Tree workspace for editable and calculable KPI driver models.",
  "license": "MIT",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10.33 <11"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15"
    }
  },
  "scripts": {
    "dev": "corepack pnpm --filter @vdt-studio/web dev",
    "build": "corepack pnpm build:cli && corepack pnpm build:web",
    "build:cli": "corepack pnpm --filter @vdt-studio/cli build",
    "build:web": "corepack pnpm --filter @vdt-studio/web build",
    "start": "corepack pnpm --filter @vdt-studio/web start",
    "lint": "corepack pnpm --filter @vdt-studio/web lint",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "vdt": "tsx packages/cli/src/bin.ts",
    "dev:all": "concurrently \"corepack pnpm dev\" \"corepack pnpm local-runner:start\"",
    "local-runner:start": "tsx packages/local-runner/src/server/index.ts",
    "local-runner:sidecar": "tsx packages/local-runner/src/sidecar/index.ts",
    "desktop:sidecar:prepare": "node scripts/prepare-desktop-sidecar.mjs",
    "desktop:sidecar:verify": "node scripts/verify-desktop-sidecar.mjs",
    "desktop:native:preflight": "node scripts/verify-desktop-native-readiness.mjs",
    "security:audit": "corepack pnpm audit --prod --audit-level high",
    "ci:verify": "node scripts/verify-ci-workflows.mjs",
    "phase7:verify": "node --import tsx scripts/verify-phase7-gate.mjs",
    "docs:verify": "node scripts/verify-release-docs.mjs",
    "certification:verify": "node scripts/verify-provider-certification.mjs",
    "evaluation:verify": "node --import tsx scripts/evaluate-providers.mjs",
    "live:codex": "node --import tsx scripts/live-subscription-cli-smoke.mjs --backend codex_subscription",
    "live:cursor": "node --import tsx scripts/live-subscription-cli-smoke.mjs --backend cursor_subscription",
    "live:copilot": "node --import tsx scripts/live-subscription-cli-smoke.mjs --backend copilot_subscription",
    "live:local-ai": "node --import tsx scripts/live-subscription-cli-smoke.mjs --backend all",
    "desktop:verify": "node scripts/verify-desktop-shell.mjs && node scripts/verify-desktop-sidecar.mjs",
    "release:bundle:verify": "node scripts/verify-release-bundle.mjs",
    "package:alpha": "node scripts/package-alpha.mjs",
    "package:verify": "node scripts/verify-cli-package.mjs",
    "release:verify": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm build && corepack pnpm ci:verify && corepack pnpm phase7:verify && corepack pnpm docs:verify && corepack pnpm security:audit && corepack pnpm certification:verify && corepack pnpm evaluation:verify && corepack pnpm package:alpha && corepack pnpm release:bundle:verify && corepack pnpm package:verify"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.0.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
